# IntelliStore AI - Environment Variables
# This is a template. The bootstrap scripts will generate .env.local with secure values.

# --- Database (PostgreSQL) ---
POSTGRES_DB=intellistore
POSTGRES_USER=intellistore_user
POSTGRES_PASSWORD=CHANGEME_GENERATED_BY_BOOTSTRAP

# --- Object Storage (MinIO) ---
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=CHANGEME_GENERATED_BY_BOOTSTRAP
MINIO_URL=http://minio:9000
MINIO_BUCKET_FILES=files
MINIO_BUCKET_QUARANTINE=quarantine

# --- Security & Encryption ---
# 256-bit (32 byte) keys base64 encoded
JWT_SECRET=CHANGEME_GENERATED_BY_BOOTSTRAP
FILE_ENCRYPTION_KEY=CHANGEME_GENERATED_BY_BOOTSTRAP

# --- AI Service ---
AI_EMBEDDING_PROVIDER=local # Options: local, openai, gemini
AI_LLM_PROVIDER=ollama      # Options: ollama, gemini, openai, anthropic
AI_EMBEDDING_API_KEY=       # Only required for openai/gemini
GEMINI_API_KEY=             # Optional for Gemini LLM/embeddings
OPENAI_API_KEY=             # Optional for OpenAI LLM/embeddings
ANTHROPIC_API_KEY=          # Optional for Anthropic LLM
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3
